# ============ 必需 ============
# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here

# ============ 主动关心 ============
PROACTIVE_ENABLED=true
PROACTIVE_INTERVAL=1800  # 间隔秒数，默认30分钟

# ============ Telegram ============
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=
# 你的 Telegram Chat ID（发送 /start 给 @userinfobot 获取）
TELEGRAM_CHAT_ID=

# ============ 微信 ============
# pip install itchat
WECHAT_ENABLED=false
WECHAT_AUTO_REPLY=true
WECHAT_REPLY_ONLY_MENTIONED=false
# 主动关心时发给谁（微信号/备注名）
WECHAT_CARE_FRIEND=

# ============ 其他 ============
PORT=5000
